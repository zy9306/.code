{
    "workbench.preferredDarkColorTheme": "Visual Studio Light",
    "workbench.colorTheme": "Visual Studio Light",
    "workbench.activityBar.location": "top",
    "workbench.startupEditor": "none",
    "workbench.tree.expandMode": "doubleClick",
    "workbench.tree.indent": 14,
    "workbench.tree.renderIndentGuides": "always",
    "workbench.panel.opensMaximized": "preserve",
    "workbench.tree.enableStickyScroll": true,
    "editor.stickyScroll.enabled": true,
    "editor.fontSize": 14,
    "editor.cursorStyle": "block",
    "editor.lineNumbers": "relative",
    "extensions.ignoreRecommendations": true,
    "explorer.confirmDelete": false,
    "search.defaultViewMode": "tree",
    "terminal.integrated.fontSize": 14,
    "diffEditor.ignoreTrimWhitespace": true,
    "go.formatTool": "goimports",
    "go.testFlags": [
        "-v"
    ],
    "emacs-mcx.strictEmacsMove": true,
    "emacs-mcx.useMetaPrefixMacCmd": true,
    "emacs-mcx.useMetaPrefixEscape": true,
    "emacs-mcx.cursorMoveOnFindWidget": true,
    "emacs-mcx.emacsLikeTab": true,
    "emacs-mcx.enableOverridingTypeCommand": true,
    "emacs-mcx.killRingMax": 500,
    "emacs-mcx.killWholeLine": true,
    "python.defaultInterpreterPath": "/Library/Frameworks/Python.framework/Versions/3.10/bin/python",
    "advancedNewFile.exclude": {
        "node_modules": true,
        "gen": true,
    },
    "gitlens.currentLine.enabled": false,
    "gitlens.codeLens.enabled": false,
    "gitlens.hovers.enabled": false,
    "gitlens.statusBar.enabled": false,
}