{
    "workbench.preferredDarkColorTheme": "Visual Studio Light",
    "workbench.colorTheme": "Visual Studio Light",
    "workbench.activityBar.location": "top",
    "workbench.startupEditor": "none",
    "workbench.list.openMode": "singleClick",
    "workbench.tree.expandMode": "doubleClick",
    "workbench.tree.indent": 14,
    "workbench.tree.renderIndentGuides": "always",
    "workbench.panel.opensMaximized": "preserve",
    "workbench.tree.enableStickyScroll": true,
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.value": 50,
    "workbench.editor.limit.excludeDirty": true,
    "update.mode": "none",
    "editor.minimap.enabled": false,
    "editor.stickyScroll.enabled": true,
    "editor.fontSize": 14,
    "editor.cursorStyle": "block",
    "editor.lineNumbers": "relative",
    "editor.parameterHints.enabled": false,
    "extensions.ignoreRecommendations": true,
    "explorer.confirmDelete": false,
    "explorer.autoReveal": false,
    "search.defaultViewMode": "tree",
    "terminal.integrated.fontSize": 14,
    "diffEditor.ignoreTrimWhitespace": true,
    "dart.closingLabels": false,
    "dart.lineLength": 120,
    "go.formatTool": "goimports",
    "go.testFlags": [
        "-v"
    ],
    "black-formatter.args": [
        "--line-length=120"
    ],
    "python.defaultInterpreterPath": "/Library/Frameworks/Python.framework/Versions/3.10/bin/python",
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "git.openRepositoryInParentFolders": "never",
    "editor.fontFamily": "Iosevka, Menlo, Monaco, 'Courier New', monospace",
    "vscode-neovim.compositeKeys": {
        "jj": {
            "command": "vscode-neovim.escape",
        },
    },
    "extensions.experimental.affinity": {
        "asvetliakov.vscode-neovim": 1
    },
}